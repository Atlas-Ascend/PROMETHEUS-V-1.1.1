+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://prometheus.local/schemas/mission.schema.json",
+  "title": "PROMETHEUS Mission",
+  "type": "object",
+  "required": ["mission_id", "objective", "seed_path", "standard_test", "challenge_test", "candidates"],
+  "properties": {
+    "mission_id": {"type": "string", "minLength": 1},
+    "objective": {"type": "string", "minLength": 1},
+    "seed_path": {"type": "string", "minLength": 1},
+    "standard_test": {"$ref": "#/$defs/command"},
+    "challenge_test": {"$ref": "#/$defs/command"},
+    "policy": {
+      "type": "object",
+      "properties": {
+        "allowed_executables": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
+        "command_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
+        "max_operations_per_candidate": {"type": "integer", "minimum": 1},
+        "max_output_chars": {"type": "integer", "minimum": 1000}
+      },
+      "additionalProperties": false
+    },
+    "candidates": {
+      "type": "array",
+      "minItems": 3,
+      "items": {"$ref": "#/$defs/candidate"}
+    }
+  },
+  "additionalProperties": false,
+  "$defs": {
+    "command": {
+      "type": "array",
+      "minItems": 1,
+      "items": {"type": "string"}
+    },
+    "operation": {
+      "type": "object",
+      "required": ["type", "path"],
+      "properties": {
+        "type": {"enum": ["write", "replace", "delete"]},
+        "path": {"type": "string", "minLength": 1},
+        "content": {"type": "string"},
+        "old": {"type": "string"},
+        "new": {"type": "string"}
+      },
+      "additionalProperties": false
+    },
+    "candidate": {
+      "type": "object",
+      "required": ["id", "strategy", "operations"],
+      "properties": {
+        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
+        "strategy": {"type": "string", "minLength": 1},
+        "operations": {"type": "array", "items": {"$ref": "#/$defs/operation"}},
+        "repair_operations": {"type": "array", "items": {"$ref": "#/$defs/operation"}}
+      },
+      "additionalProperties": false
+    }
+  }
+}
