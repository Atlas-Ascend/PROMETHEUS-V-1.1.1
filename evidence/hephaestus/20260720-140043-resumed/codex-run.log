+def _write_packet(root: Path, packet_id: str, packet_type: str, payload: dict[str, Any]) -> dict[str, Any]:
+    packet = {
+        "schema": "prometheus.packet.v1",
+        "packet_id": packet_id,
+        "packet_type": packet_type,
+        "payload": payload,
