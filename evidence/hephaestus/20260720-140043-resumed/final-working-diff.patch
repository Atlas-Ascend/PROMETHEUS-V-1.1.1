+      - name: Install
+        run: python -m pip install -e .
+      - name: Test kernel
+        run: python -m unittest discover -s tests -v
+      - name: Execute P0 mission
+        run: prometheus run missions/bootstrap.json
+      - name: Verify latest receipt
+        shell: bash
+        run: |
+          receipt=$(find .prometheus/runs -name promotion-receipt.json -type f | sort | tail -n 1)
+          prometheus verify "$receipt"
+      - name: Preserve P0 proof bundle
+        uses: actions/upload-artifact@v4
+        with:
+          name: prometheus-p0-proof-${{ github.sha }}
+          path: .prometheus/runs/
